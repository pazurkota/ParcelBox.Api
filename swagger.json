{
  "openapi": "3.0.4",
  "info": {
    "title": "ParcelBox.Api, Version=1.0.0.0, Culture=neutral, PublicKeyToken=null",
    "version": "1.0"
  },
  "paths": {
    "/api/Lockers": {
      "get": {
        "tags": [
          "Lockers"
        ],
        "summary": "Get all lockers",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/GetLockerDto"
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/api/Lockers/{id}": {
      "get": {
        "tags": [
          "Lockers"
        ],
        "summary": "Gets a locker by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "The ID of a locker",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetLockerDto"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/api/Lockers/create": {
      "post": {
        "tags": [
          "Lockers"
        ],
        "summary": "Creates a new locker",
        "requestBody": {
          "description": "The locker to be created",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateLockerDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateLockerDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CreateLockerDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetLockerDto"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/api/Lockers/{id}/boxes": {
      "patch": {
        "tags": [
          "Lockers"
        ],
        "summary": "Creates a locker boxes in a locker",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "The ID of a locker",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "requestBody": {
          "description": "An array of locker boxes to be created",
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/CreateLockerBoxDto"
                }
              }
            },
            "text/json": {
              "schema": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/CreateLockerBoxDto"
                }
              }
            },
            "application/*+json": {
              "schema": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/CreateLockerBoxDto"
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetLockerDto"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/api/Lockers/{id}/edit": {
      "put": {
        "tags": [
          "Lockers"
        ],
        "summary": "Edits the locker",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "The ID of a locker",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "requestBody": {
          "description": "The data to be edited",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EditLockerDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/EditLockerDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/EditLockerDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CreateLockerBoxDto": {
        "required": [
          "lockerSize"
        ],
        "type": "object",
        "properties": {
          "lockerSize": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "CreateLockerDto": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "nullable": true
          },
          "address": {
            "type": "string",
            "nullable": true
          },
          "city": {
            "type": "string",
            "nullable": true
          },
          "postalCode": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "EditLockerDto": {
        "type": "object",
        "properties": {
          "address": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "GetLockerDto": {
        "required": [
          "address",
          "city",
          "code",
          "postalCode"
        ],
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "nullable": true
          },
          "address": {
            "type": "string",
            "nullable": true
          },
          "city": {
            "type": "string",
            "nullable": true
          },
          "postalCode": {
            "type": "string",
            "nullable": true
          },
          "lockerBoxes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/LockerBox"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "LockerBox": {
        "required": [
          "lockerSize"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "lockerSize": {
            "type": "string",
            "nullable": true
          },
          "isOccupied": {
            "type": "boolean"
          },
          "lockerId": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "ProblemDetails": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "nullable": true
          },
          "title": {
            "type": "string",
            "nullable": true
          },
          "status": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "detail": {
            "type": "string",
            "nullable": true
          },
          "instance": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": { }
      }
    }
  },
  "tags": [
    {
      "name": "Lockers"
    }
  ]
}